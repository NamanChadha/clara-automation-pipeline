# Clara Automation Pipeline - Environment Variables
# Copy this to .env and fill in values

# Retell API Key (optional - only needed for direct API integration)
# Free tier: $10 credits included
RETELL_API_KEY=your_retell_api_key_here

# n8n Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Data paths (defaults work for Docker setup)
DATA_DIR=./data
OUTPUT_DIR=./outputs
